# ローカル開発用環境変数（コピーして .env を作成 · Git に含めない）
# npm run dev 起動時に deploy/cloudflare/dist/.dev.vars へ自動同期（Pages Functions binding）
# 手動配置例: deploy/cloudflare/.dev.vars.example → dist/.dev.vars

# AI 運営秘書 — DeepSeek（サーバー側のみ · クライアントへ渡さない）
DEEPSEEK_API_KEY=
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# TLV Live ZEGO PoC（サーバー側のみ · Token 発行 API）
# ZEGOCLOUD Console → AppID / Server / ServerSecret（32 byte）
ZEGO_APP_ID=
ZEGO_SERVER=
ZEGO_SERVER_SECRET=

# Supabase（ビルド / 検証スクリプト用 · 既存）
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
